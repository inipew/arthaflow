    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "svelte": "^5.17.3",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "wrangler": "^3.101.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "lucide-svelte": "latest"
  }
